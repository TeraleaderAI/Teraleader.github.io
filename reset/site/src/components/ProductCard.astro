---
const { product } = Astro.props;
---
<article class="product-card">
  <img class="product-card__image" src={product.cardImage || product.image} alt={`${product.name} 제품 이미지`} loading="lazy" />
  <div class="product-card__body">
    <div class="product-card__topline">
      <p class="product-card__meta">{product.category}</p>
      <span class="product-card__order">{String(product.order).padStart(2, '0')}</span>
    </div>
    <h3>{product.name}</h3>
    <p class="product-card__subtitle">{product.subtitle}</p>
    <p>{product.summary}</p>
    {product.tags?.length > 0 && (
      <div class="tag-list" aria-label={`${product.name} 태그`}>
        {product.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
      </div>
    )}
    <a class="btn btn-secondary" href={`/products/${product.id}/`}>상세 보기</a>
  </div>
</article>
