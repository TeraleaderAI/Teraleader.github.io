---
import BaseLayout from '../../layouts/BaseLayout.astro';
import notices from '../../data/notices.json';
import company from '../../data/company.json';

export function getStaticPaths() {
  return notices.map((notice) => ({
    params: { id: notice.id },
    props: { notice }
  }));
}

const { notice } = Astro.props;
---
<BaseLayout title={`${notice.title} | ${company.name}`} description={notice.body}>
  <main>
    <section class="page-hero">
      <div class="container">
        <p class="eyebrow">Notice</p>
        <h1>{notice.title}</h1>
        <p>{notice.date}</p>
      </div>
    </section>

    <section class="section">
      <div class="container detail-card prose">
        <p>{notice.body}</p>
        <div class="detail-actions">
          <a class="btn btn-secondary" href="/notices/">목록으로</a>
          <a class="btn btn-primary" href="/support/">문의하기</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
