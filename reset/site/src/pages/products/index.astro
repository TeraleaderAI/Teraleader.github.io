---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import products from '../../data/products.json';
import company from '../../data/company.json';

const visibleProducts = products.filter((product) => product.visible).sort((a, b) => a.order - b.order);
---
<BaseLayout title={`제품안내 | ${company.name}`} current="products">
  <main>
    <section class="page-hero">
      <div class="container">
        <p class="eyebrow">Products</p>
        <h1>제품안내</h1>
        <p>연구 목적과 실험 조건에 맞춘 셀 지그, 온도 제어, 압력 제어, 열분석 장비를 확인할 수 있습니다.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-header">
          <div>
            <h2 class="section-title">제품 목록</h2>
            <p class="section-desc">제품 정보는 데이터 파일에서 관리되며, 노출 상태가 켜진 제품만 이 페이지에 표시됩니다.</p>
          </div>
        </div>
        <div class="grid product-grid">
          {visibleProducts.map((product) => <ProductCard product={product} />)}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
