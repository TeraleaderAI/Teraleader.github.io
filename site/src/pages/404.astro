---
import BaseLayout from '../layouts/BaseLayout.astro';
import company from '../data/company.json';
---
<BaseLayout title={`페이지를 찾을 수 없습니다 | ${company.name}`} description="요청한 페이지를 찾을 수 없습니다.">
  <main>
    <section class="page-hero">
      <div class="container">
        <p class="eyebrow">404</p>
        <h1>페이지를 찾을 수 없습니다</h1>
        <p>주소가 변경되었거나 삭제된 페이지입니다.</p>
      </div>
    </section>

    <section class="section">
      <div class="container empty-state">
        <p>제품 정보는 제품안내 페이지에서 확인할 수 있습니다.</p>
        <div class="hero-actions" style="justify-content:center;">
          <a class="btn btn-primary" href="/products/">제품안내</a>
          <a class="btn btn-secondary" href="/index.html">홈으로</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
