---
import BaseLayout from '../layouts/BaseLayout.astro';
import company from '../data/company.json';
---
<BaseLayout title={`회사소개 | ${company.name}`} current="company">
  <main>
    <section class="page-hero">
      <div class="container">
        <p class="eyebrow">About Us</p>
        <h1>회사소개</h1>
        <p>{company.summary}</p>
      </div>
    </section>

    <section class="section">
      <div class="container grid info-grid">
        <article class="info-panel">
          <h3>사업영역</h3>
          <ul>
            {company.businessAreas.map((area) => <li>{area}</li>)}
          </ul>
        </article>
        <article class="info-panel">
          <h3>연락처</h3>
          <p>{company.address}</p>
          <p>Tel. {company.tel}<br />Fax. {company.fax}<br />Email. <a href={`mailto:${company.email}`}>{company.email}</a></p>
        </article>
        <article class="info-panel">
          <h3>운영 방향</h3>
          <p>제품 문의와 A/S 접수는 이메일과 전화로 통합해 빠르게 확인할 수 있도록 운영합니다.</p>
        </article>
      </div>
    </section>

    <section class="section" style="padding-top:0;">
      <div class="container">
        <div class="section-header">
          <div>
            <h2 class="section-title">연혁</h2>
            <p class="section-desc">구버전 홈페이지의 연혁 자료를 기준으로 정리했습니다.</p>
          </div>
        </div>
        <div class="grid">
          {company.history.map((entry) => (
            <article class="detail-card">
              <h3>{entry.year}</h3>
              <ul>
                {entry.items.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
