---
import BaseLayout from '../../layouts/BaseLayout.astro';
import products from '../../data/products.json';
import company from '../../data/company.json';

export function getStaticPaths() {
  return products
    .filter((product) => product.visible)
    .map((product) => ({
      params: { id: product.id },
      props: { product }
    }));
}

const { product } = Astro.props;
---
<BaseLayout title={`${product.name} | ${company.name}`} current="products">
  <main>
    <section class="page-hero">
      <div class="container">
        <p class="eyebrow">{product.category}</p>
        <h1>{product.name}</h1>
        <p>{product.summary}</p>
      </div>
    </section>

    <section class="section">
      <div class="container detail-layout">
        <div class="product-visual">
          <img src={product.image || product.cardImage} alt={`${product.name} 상세 이미지`} />
        </div>
        <article class="detail-card">
          <h2 class="section-title">제품 개요</h2>
          <p class="eyebrow">{product.subtitle}</p>
          <p>{product.description}</p>
          {product.tags?.length > 0 && (
            <div class="tag-list" aria-label="제품 태그">
              {product.tags.map((tag) => <span>{tag}</span>)}
            </div>
          )}
          {product.features.length > 0 && (
            <>
              <h3>특징</h3>
              <ul>
                {product.features.map((feature) => <li>{feature}</li>)}
              </ul>
            </>
          )}
          {product.downloads.length > 0 && (
            <div class="download-list">
              {product.downloads.map((download) => (
                <a class="btn btn-secondary" href={download.file}>{download.label}</a>
              ))}
            </div>
          )}
          <div class="detail-actions">
            <a class="btn btn-primary" href={`mailto:${company.email}?subject=${encodeURIComponent(product.inquirySubject || `[TeraLeader] ${product.name} 제품 문의`)}`}>제품 문의</a>
            <a class="btn btn-secondary" href="/products/">목록으로</a>
          </div>
        </article>
      </div>
    </section>

    {product.specs.length > 0 && (
      <section class="section" style="padding-top:0;">
        <div class="container detail-card">
          <h2 class="section-title">주요 사양</h2>
          <table class="spec-table">
            <tbody>
              {product.specs.map((spec) => (
                <tr>
                  <th>{spec.name}</th>
                  <td>{spec.value}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}
  </main>
</BaseLayout>
